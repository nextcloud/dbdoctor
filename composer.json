{
    "name": "nextcloud/dbdoctor",
    "description": "Audit MySQL/MariaDB/PostgreSQL configuration of a Nextcloud server",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "nextcloud/ocp": "dev-master",
        "phpunit/phpunit": "^10.0",
        "vimeo/psalm": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "OCA\\DBDoctor\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\DBDoctor\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration tests/phpunit.xml",
        "psalm": "psalm --no-cache"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.3"
        },
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    }
}
